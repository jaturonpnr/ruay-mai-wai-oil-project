<!-- Workaround: MSBuild URL-encodes '@' in paths when resolving glob imports in
     Microsoft.Common.props. The workspace directory name contains '@github.com'
     which breaks the NuGet props glob. Redirect obj/ to /tmp where the path is clean. -->
<Project>
  <PropertyGroup>
    <!-- Workaround: '@' in the workspace directory name causes MSBuild to
         URL-encode it ('%40'), breaking NuGet glob imports AND preventing
         CoreCLR from loading the native runtime. Redirect both obj/ and bin/
         to /tmp paths that contain no special characters. -->
    <BaseIntermediateOutputPath>/tmp/fuelcalc-obj/</BaseIntermediateOutputPath>
    <MSBuildProjectExtensionsPath>/tmp/fuelcalc-obj/</MSBuildProjectExtensionsPath>
    <BaseOutputPath>/tmp/fuelcalc-bin/</BaseOutputPath>
  </PropertyGroup>
</Project>
